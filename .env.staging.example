# Vottery Staging Environment Variables Example
# Copy this to .env.staging and fill in the values

# --- CORE (Required) ---
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://your-staging-api.com
VITE_ENV=staging

# --- MONITORING (Required for Staging) ---
VITE_SENTRY_DSN=https://sentry-dsn-staging@sentry.io/123
VITE_GA_MEASUREMENT_ID=G-STAGING123

# --- PAYMENTS (Staging/Test Mode) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_123

# --- OPTIONAL MODULES (If missing, module will auto-disable) ---

# AI Orchestration
VITE_GEMINI_API_KEY=
VITE_CLAUDE_API_KEY=
VITE_PERPLEXITY_API_KEY=
VITE_SHAPED_API_KEY=

# Maps & Captcha
VITE_GOOGLE_MAPS_API_KEY=
VITE_HCAPTCHA_SITE_KEY=

# Comms (Keys set in Supabase Secrets for Edge Functions)
# PLATFORM_GAMIFICATION_API_KEY
# TELNYX_API_KEY
# TWILIO_ACCOUNT_SID
# TWILIO_AUTH_TOKEN

# KYC (Keys set in Supabase Secrets for Edge Functions)
# SUMSUB_TOKEN
# SUMSUB_SECRET
# VERIFF_API_KEY
# VERIFF_SHARED_SECRET
